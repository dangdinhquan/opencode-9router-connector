{
  "name": "@dendaio/opencode-9router-plugin",
  "version": "0.1.0",
  "description": "OpenCode plugin for OpenAI-compatible auto model discovery",
  "repository": {
    "url": "https://github.com/dangdinhquan/opencode-9router-connector"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --sourcemap --clean",
    "dev": "tsup src/index.ts --format esm --dts --sourcemap --watch",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "opencode",
    "plugin",
    "openai",
    "models"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.0"
  }
}
